# ─── MongoDB ───────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/salespulse_crm
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/salespulse_crm

# ─── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=30d

# ─── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=SalesPulse CRM <no-reply@salespulse.com>

# ─── Frontend URL (for CORS) ───────────────────────
CLIENT_URL=http://localhost:5000

# ─── Reminder Lead Time (minutes before action) ────
REMINDER_LEAD_MINUTES=15
